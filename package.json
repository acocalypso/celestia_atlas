{
  "name": "@acocalypso/celestia-atlas",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./catalog-data": "./data/openngc-catalog.json",
    "./viewer-catalog-data": "./data/openngc-viewer-catalog.json",
    "./normalized-catalog-data": "./data/dso-catalog.json",
    "./normalized-viewer-catalog-data": "./data/dso-viewer-catalog.json",
    "./catalog-sources": "./data/catalog-sources.json",
    "./openngc-catalog-data": "./data/openngc-catalog.json",
    "./openngc-viewer-catalog-data": "./data/openngc-viewer-catalog.json",
    "./bright-sky-data": "./data/bright-sky.json",
    "./comet-data": "./data/comets.json"
  },
  "types": "./src/index.d.ts",
  "scripts": {
    "test": "npm run test:js && npm run test:catalog",
    "test:js": "node --test tests/*.test.js",
    "test:catalog": "python -m unittest discover -s tests -p \"test_catalog_*.py\"",
    "test:browser": "node tools/browser_smoke_test.mjs",
    "build:dso": "python tools/build_dso_catalog.py",
    "fetch:catalog-sources": "python tools/fetch_catalog_sources.py --acknowledge-rights-review",
    "build:bright-sky": "node tools/build_bright_sky_catalog.mjs",
    "build:comets": "node tools/build_comet_catalog.mjs"
  },
  "dependencies": {
    "astronomy-engine": "2.1.19"
  }
}
